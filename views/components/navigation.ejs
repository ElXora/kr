<% const now = new Date(); %>
<!-- BW Theme Navigation -->
<head>
  <link rel="icon" type="image/x-icon" href="../assets/favicon.png">
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
  <style>
    @keyframes glow-pulse {
      0%, 100% { box-shadow: 0 0 4px rgba(255,255,255,0.15); }
      50% { box-shadow: 0 0 12px rgba(255,255,255,0.35); }
    }
    @keyframes slide-in-left {
      from { transform: translateX(-20px); opacity: 0; }
      to   { transform: translateX(0);    opacity: 1; }
    }
    @keyframes fade-up {
      from { transform: translateY(8px); opacity: 0; }
      to   { transform: translateY(0);   opacity: 1; }
    }
    .nav-item { animation: fade-up 0.35s ease both; }
    .nav-item:nth-child(1)  { animation-delay: 0.04s; }
    .nav-item:nth-child(2)  { animation-delay: 0.08s; }
    .nav-item:nth-child(3)  { animation-delay: 0.12s; }
    .nav-item:nth-child(4)  { animation-delay: 0.16s; }
    .nav-item:nth-child(5)  { animation-delay: 0.20s; }
    .nav-item:nth-child(6)  { animation-delay: 0.24s; }
    .nav-item:nth-child(7)  { animation-delay: 0.28s; }
    .sidebar-card { animation: slide-in-left 0.4s ease both; }
    .user-card-glow { animation: glow-pulse 3s infinite; }
    .nav-link-bw {
      display: flex; align-items: center;
      padding: 0.5rem 1rem; border-radius: 0.5rem;
      color: #d1d5db; font-size: 0.875rem; font-weight: 500;
      background: #111111; border: 1px solid #222;
      transition: all 0.2s ease;
    }
    .nav-link-bw:hover {
      background: #1f1f1f; color: #ffffff;
      border-color: #444; transform: scale(0.97);
      box-shadow: 0 0 8px rgba(255,255,255,0.08);
    }
    .nav-link-bw.active {
      background: #fff; color: #000;
      border-color: #fff;
    }
    .nav-link-bw svg { margin-right: 0.5rem; color: #6b7280; flex-shrink: 0; }
    .nav-link-bw:hover svg, .nav-link-bw.active svg { color: inherit; }
  </style>
</head>

<body class="animate__animated animate__fadeIn"></body>

<!-- Mobile bottom nav -->
<div class="md:hidden fixed rounded-t-2xl bottom-0 left-0 right-0 bg-[#0a0a0a] border-t border-white/10 z-50 backdrop-blur-sm">
  <div class="flex justify-around items-center h-16">
    <a href="/dashboard" class="flex flex-col items-center justify-center text-gray-400 hover:text-white transition-colors flex-1 h-full">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      <span class="text-xs mt-0.5">Home</span>
    </a>
    <a href="/store" class="flex flex-col items-center justify-center text-gray-400 hover:text-white transition-colors flex-1 h-full">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      <span class="text-xs mt-0.5">Shop</span>
    </a>
    <a href="/servers/new" class="flex flex-col items-center justify-center text-white flex-1 h-full">
      <div class="w-9 h-9 rounded-full bg-white flex items-center justify-center mb-0.5">
        <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      </div>
      <span class="text-xs">New</span>
    </a>
    <a href="/earn" class="flex flex-col items-center justify-center text-gray-400 hover:text-white transition-colors flex-1 h-full">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span class="text-xs mt-0.5">Earn</span>
    </a>
    <a href="/profile" class="flex flex-col items-center justify-center text-gray-400 hover:text-white transition-colors flex-1 h-full">
      <div class="w-6 h-6 rounded-full overflow-hidden border border-gray-500">
        <img src="<%= req.session.userinfo.avatar ? `https://cdn.discordapp.com/avatars/${req.session.userinfo.id}/${req.session.userinfo.avatar}.png` : '/default-avatar.png' %>" alt="Profile" class="w-full h-full object-cover">
      </div>
      <span class="text-xs mt-0.5">Profile</span>
    </a>
  </div>
</div>

<!-- Desktop sidebar -->
<nav x-data="{ open: false }" class="relative">
  <div class="hidden md:flex md:flex-col md:w-64 md:min-h-screen md:bg-[#080808] md:border-r md:border-white/10 md:p-4 sidebar-card">

    <!-- Logo -->
    <div class="flex items-center mb-6 px-1">
      <img class="w-9 h-9 mr-2.5 rounded-lg border border-white/20" src="<%= settings.logo %>" alt="Logo">
      <span class="text-xl font-bold text-white tracking-tight"><%= settings.name %></span>
    </div>

    <!-- User card -->
    <div class="user-card-glow flex items-center p-3 mb-6 rounded-xl bg-[#111] border border-white/15 hover:border-white/30 transition-all duration-300 cursor-default">
      <img alt="Avatar" class="mr-3 rounded-full w-10 h-10 border border-white/20 object-cover"
        src="https://cdn.discordapp.com/avatars/<%= req.session.userinfo.id %>/<%= req.session.userinfo.avatar %>.png?size=128">
      <div class="overflow-hidden">
        <div class="font-semibold text-white text-sm truncate"><%= req.session.userinfo.username %></div>
        <div class="text-xs text-gray-400"><%= coins %> <%= settings.api.client.coins.name %></div>
      </div>
    </div>

    <!-- Create server CTA -->
    <a href="/servers/new" class="mb-5 flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-white text-black font-semibold text-sm hover:bg-gray-100 transition-all hover:scale-95 shadow-lg shadow-white/10">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256"><path d="M228,128a12,12,0,0,1-12,12H140v76a12,12,0,0,1-24,0V140H40a12,12,0,0,1,0-24h76V40a12,12,0,0,1,24,0v76h76A12,12,0,0,1,228,128Z"></path></svg>
      Create a Server
    </a>

    <!-- Nav links -->
    <nav>
      <ul class="space-y-1">
        <li class="nav-item">
          <a href="/dashboard" class="nav-link-bw">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a href="/store" class="nav-link-bw">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            Shop
          </a>
        </li>
        <li class="nav-item">
          <a href="/profile" class="nav-link-bw">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M3.665 3.588A2 2 0 0 1 5.622 2h4.754a2 2 0 0 1 1.958 1.588l1.098 5.218a3.487 3.487 0 0 0-1.433-.306H4c-.51 0-.995.11-1.433.306l1.099-5.218Z"/><path fill-rule="evenodd" d="M4 10a2 2 0 1 0 0 4h8a2 2 0 1 0 0-4H4Zm8 2.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5ZM9.75 12a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" clip-rule="evenodd"/></svg>
            Control Panel
          </a>
        </li>
        <li class="nav-item">
          <a href="/earn" class="nav-link-bw">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M2.273 5.625A4.483 4.483 0 0 1 5.25 4.5h13.5c1.141 0 2.183.425 2.977 1.125A3 3 0 0 0 18.75 3H5.25a3 3 0 0 0-2.977 2.625ZM5.25 9a3 3 0 0 0-3 3v6a3 3 0 0 0 3 3h13.5a3 3 0 0 0 3-3v-6a3 3 0 0 0-3-3H15a.75.75 0 0 0-.75.75 2.25 2.25 0 0 1-4.5 0A.75.75 0 0 0 9 9H5.25Z"/></svg>
            Earn Coins
          </a>
        </li>
        <li class="nav-item">
          <a href="#" class="nav-link-bw">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path d="M7 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM14.5 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM1.615 16.428a1.224 1.224 0 0 1-.569-1.175 6.002 6.002 0 0 1 11.908 0c.058.467-.172.92-.57 1.174A9.953 9.953 0 0 1 7 18a9.953 9.953 0 0 1-5.385-1.572ZM14.5 16h-.106c.07-.297.088-.611.048-.933a7.47 7.47 0 0 0-1.588-3.755 4.502 4.502 0 0 1 5.874 2.636.818.818 0 0 1-.36.98A7.465 7.465 0 0 1 14.5 16Z"/></svg>
            Referrals
          </a>
        </li>
        <li class="nav-item">
          <a href="/security" class="nav-link-bw">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z" clip-rule="evenodd"/></svg>
            Settings
          </a>
        </li>
        <li class="nav-item pt-1">
          <a href="../logout" class="flex items-center px-4 py-2 rounded-lg text-sm font-medium text-red-400 bg-[#111] border border-red-900/40 hover:bg-red-950/40 hover:text-red-300 hover:border-red-800 transition-all hover:scale-97">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mr-2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75"/></svg>
            Logout
          </a>
        </li>
      </ul>
    </nav>

    <!-- Admin section -->
    <% if (pterodactyl.root_admin == true) { %>
    <div class="mt-4 rounded-xl p-3 bg-[#0f0f0f] border border-white/10">
      <p class="text-xs text-gray-500 font-semibold uppercase tracking-widest mb-2 px-1">Admin</p>
      <a href="../admin" class="flex items-center px-3 py-2 rounded-lg text-sm font-medium text-white bg-white/10 border border-white/20 hover:bg-white hover:text-black transition-all hover:scale-97">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 20 20" class="mr-2"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z" clip-rule="evenodd"/></svg>
        Admin Panel
      </a>
    </div>
    <% } %>

    <!-- Footer -->
    <div class="mt-auto pt-4 border-t border-white/10">
      <p class="text-xs text-gray-600 text-center"><%= settings.name %> &bull; Powered by Heliactyl</p>
    </div>
  </div>
</nav>
