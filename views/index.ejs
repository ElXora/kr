<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= settings.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { height: 100%; background: #080808; color: #f0f0f0; overflow-x: hidden; }
    body { font-family: 'Inter', system-ui, sans-serif; }

    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes gridScroll {
      from { background-position: 0 0; }
      to   { background-position: 40px 40px; }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-18px); }
    }
    @keyframes borderPulse {
      0%, 100% { border-color: rgba(255,255,255,0.12); }
      50%       { border-color: rgba(255,255,255,0.28); }
    }
    @keyframes shimmer {
      0%   { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }

    .fade-up   { animation: fadeSlideUp 0.5s ease both; }
    .delay-1   { animation-delay: 0.1s; }
    .delay-2   { animation-delay: 0.2s; }
    .delay-3   { animation-delay: 0.3s; }

    /* Animated grid bg */
    .grid-bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      animation: gridScroll 8s linear infinite;
    }
    .grid-bg::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 50%, transparent 30%, #080808 100%);
    }

    /* Login card */
    .login-card {
      background: rgba(15,15,15,0.9); backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 1.5rem; padding: 2rem;
      animation: borderPulse 4s infinite;
    }

    .input-bw {
      width: 100%; padding: 0.65rem 0.9rem;
      background: #111; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 0.6rem; color: #f0f0f0;
      font-size: 0.875rem; outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .input-bw:focus {
      border-color: rgba(255,255,255,0.35);
      box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
    }
    .input-bw::placeholder { color: #555; }

    .btn-primary {
      width: 100%; padding: 0.65rem;
      background: #fff; color: #000; border: none;
      border-radius: 0.6rem; font-size: 0.875rem; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .btn-primary:hover { background: #e5e5e5; transform: scale(0.98); }

    .btn-discord {
      width: 100%; display: flex; align-items: center; justify-content: center;
      gap: 0.6rem; padding: 0.65rem;
      background: #5865F2; color: #fff; border-radius: 0.6rem;
      font-size: 0.875rem; font-weight: 600;
      transition: all 0.2s; border: none; cursor: pointer;
    }
    .btn-discord:hover { background: #4752c4; transform: scale(0.98); }

    .divider { display: flex; align-items: center; gap: 0.75rem; margin: 1rem 0; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.1); }
    .divider span { font-size: 0.75rem; color: #555; }

    .label-bw { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #777; margin-bottom: 0.3rem; display: block; }
  </style>
</head>
<body>
  <div class="grid-bg"></div>

  <div class="relative z-10 min-h-screen flex flex-col">
    <!-- Top bar -->
    <header class="flex items-center justify-between px-6 py-5">
      <div class="flex items-center gap-3 fade-up">
        <img src="<%= settings.logo %>" class="w-9 h-9 rounded-lg border border-white/20" alt="Logo">
        <span class="text-lg font-bold text-white"><%= settings.name %></span>
      </div>
      <div class="fade-up delay-1 text-xs text-gray-600">Free Minecraft Hosting</div>
    </header>

    <!-- Center content -->
    <main class="flex-1 flex flex-col lg:flex-row items-center justify-center gap-12 px-6 pb-12">

      <!-- Left: Branding -->
      <div class="hidden lg:flex flex-col gap-6 max-w-md fade-up delay-1">
        <div>
          <h1 class="text-5xl font-extrabold text-white leading-tight">
            Free<br>
            <span class="text-gray-400">Minecraft</span><br>
            Hosting.
          </h1>
          <p class="mt-4 text-gray-500 text-lg leading-relaxed">
            Deploy servers instantly. No credit card required. Powered by Pterodactyl.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <div class="w-1.5 h-1.5 rounded-full bg-white/50"></div>
            Free server slots included
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <div class="w-1.5 h-1.5 rounded-full bg-white/50"></div>
            Earn coins via AFK & referrals
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <div class="w-1.5 h-1.5 rounded-full bg-white/50"></div>
            Instant setup, no waiting
          </div>
        </div>
      </div>

      <!-- Right: Login card -->
      <div class="login-card w-full max-w-sm fade-up delay-2">
        <h2 class="text-xl font-bold text-white mb-1">Welcome back 👾</h2>
        <p class="text-sm text-gray-500 mb-6">Sign in to manage your servers.</p>

        <!-- Discord OAuth (primary) -->
        <a href="/login" class="btn-discord block text-center no-underline mb-3">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512"><path fill="currentColor" d="M524.5 69.8a1.5 1.5 0 0 0-.8-.7A485.1 485.1 0 0 0 404.1 32a1.8 1.8 0 0 0-1.9.9 337.5 337.5 0 0 0-14.9 30.6 447.8 447.8 0 0 0-134.4 0 309.5 309.5 0 0 0-15.1-30.6 1.9 1.9 0 0 0-1.9-.9A483.7 483.7 0 0 0 116.1 69.1a1.7 1.7 0 0 0-.8.7C39.1 183.7 18.2 294.7 28.4 404.4a2 2 0 0 0 .8 1.4A487.7 487.7 0 0 0 176 479.9a1.9 1.9 0 0 0 2.1-.7A348.2 348.2 0 0 0 208.1 430.4a1.9 1.9 0 0 0-1-2.6 321.2 321.2 0 0 1-45.9-21.9 1.9 1.9 0 0 1-.2-3.1c3.1-2.3 6.2-4.7 9.1-7.1a1.8 1.8 0 0 1 1.9-.3c96.2 43.9 200.4 43.9 295.5 0a1.8 1.8 0 0 1 1.9.2c2.9 2.4 6 4.9 9.1 7.2a1.9 1.9 0 0 1-.2 3.1 301.4 301.4 0 0 1-45.9 21.8 1.9 1.9 0 0 0-1 2.6 391.1 391.1 0 0 0 30 48.8 1.9 1.9 0 0 0 2.1.7A486 486 0 0 0 610.7 405.7a1.9 1.9 0 0 0 .8-1.4C623.7 277.6 590.9 167.5 524.5 69.8zM222.5 337.6c-29 0-52.8-26.6-52.8-59.2S193.1 219.1 222.5 219.1c29.7 0 53.3 26.8 52.8 59.2C275.3 311 251.9 337.6 222.5 337.6zm195.4 0c-29 0-52.8-26.6-52.8-59.2S388.4 219.1 417.9 219.1c29.7 0 53.3 26.8 52.8 59.2C470.7 311 447.5 337.6 417.9 337.6z"/></svg>
          Continue with Discord
        </a>

        <div class="divider"><span>or admin login</span></div>

        <!-- Admin login form — POSTs to /adminlogin, bypasses Discord OAuth -->
        <form action="/adminlogin" method="POST" class="flex flex-col gap-3">
          <% if (typeof query !== 'undefined' && query.error) { %>
          <div style="background:rgba(255,60,60,0.12);border:1px solid rgba(255,60,60,0.3);border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.78rem;color:#ff6b6b;">
            <% if (query.error === 'invalid_credentials') { %>Invalid username or password.<% } %>
            <% if (query.error === 'not_admin') { %>This account does not have admin access.<% } %>
            <% if (query.error === 'missing_credentials') { %>Please enter your username and password.<% } %>
            <% if (query.error === 'server_error') { %>A server error occurred. Please try again.<% } %>
          </div>
          <% } %>
          <div>
            <label class="label-bw">Pterodactyl Username</label>
            <input type="text" name="username" class="input-bw" placeholder="admin" autocomplete="username" required>
          </div>
          <div>
            <label class="label-bw">Password</label>
            <input type="password" name="password" class="input-bw" placeholder="••••••••" autocomplete="current-password" required>
          </div>
          <button type="submit" class="btn-primary mt-1">Admin Login</button>
        </form>

        <div class="flex items-center justify-between mt-4 text-xs text-gray-500">
          <span>Regular user? <a href="/login" class="text-white hover:underline">Login with Discord</a></span>
        </div>
      </div>
    </main>

    <%- include('./components/footer') %>
  </div>
</body>
</html>
